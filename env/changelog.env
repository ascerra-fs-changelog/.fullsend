export GITHUB_ISSUE_URL="${GITHUB_ISSUE_URL}"
export ISSUE_NUMBER="${ISSUE_NUMBER}"

# READ-ONLY scoped app installation token.
# This token CANNOT push code or create PRs.
export GH_TOKEN="${GH_TOKEN}"

export GIT_AUTHOR_NAME="fullsend-changelog"
export GIT_AUTHOR_EMAIL="fullsend-changelog@users.noreply.github.com"
export GIT_COMMITTER_NAME="fullsend-changelog"
export GIT_COMMITTER_EMAIL="fullsend-changelog@users.noreply.github.com"

export MAX_RETRIES=1
export TIMEOUT_SECONDS=600
